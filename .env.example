# =============================================================================
# gws-reauth-web-client — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.

# -- Required ------------------------------------------------------------------

# Web OAuth client credentials from Google Cloud Console
# (This is a separate "Web application" client — NOT your gws Desktop client)
GWS_WEB_CLIENT_ID=your-web-client-id.apps.googleusercontent.com
GWS_WEB_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxxxxxxxxxxxxx

# Full redirect URI — must match exactly what you set in GCP
GWS_REDIRECT_URI=https://gws-reauth.example.com/oauth2/callback

# Paths to gws's encrypted credential store
GWS_ENCRYPTION_KEY_PATH=/home/user/.config/gws/.encryption_key
GWS_CREDENTIALS_ENC_PATH=/home/user/.config/gws/credentials.enc

# Bearer token for the internal /api/internal/mint endpoint
# Generate one with: openssl rand -hex 32
MINT_BEARER=your-secret-bearer-token

# -- Optional ------------------------------------------------------------------

# Directory containing gws token cache files (cleared on successful reauth)
# GWS_TOKEN_CACHE_DIR=/home/user/.config/gws

# OAuth scopes (space-separated; defaults to gmail, drive, calendar, tasks)
# GWS_SCOPES=https://mail.google.com/ https://www.googleapis.com/auth/drive https://www.googleapis.com/auth/calendar https://www.googleapis.com/auth/tasks

# Listening port (default: 3000)
# PORT=3000

# Directory for persistent state — tokens and sessions (default: ./data)
# DATA_DIR=./data

# Single-use link TTL in days (default: 7)
# LINK_TTL_DAYS=7

# -- Notifications (optional) --------------------------------------------------

# Telegram bot token and chat ID for success/failure notifications
# TELEGRAM_BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11
# TELEGRAM_CHAT_ID=123456789
